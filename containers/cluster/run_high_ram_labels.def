Bootstrap: docker
From: python:3.11-slim

%files
    . /app

%post
    apt-get update
    apt-get install -y --no-install-recommends gcc g++
    rm -rf /var/lib/apt/lists/*

    cd /app
    pip install --no-cache-dir -r requirements.txt
    pip install --no-cache-dir nibabel scikit-learn

%environment
    export PYTHONUNBUFFERED=1
    export APP_ROOT=/app
    export DEFAULT_SEGMENTATION=/app/data/reference/MNI152_T1_1mm_seg.nii.gz

%runscript
    set -eu

    export OPENBLAS_NUM_THREADS="${OPENBLAS_NUM_THREADS:-64}"

    ensure_dir_writable() {
        target_dir="$1"
        mkdir -p "${target_dir}"

        probe_path="${target_dir}/.write_test_$$"
        if ! : > "${probe_path}"; then
            echo "Cannot write to ${target_dir}. Check directory permissions before running." >&2
            exit 1
        fi
        rm -f "${probe_path}"
    }

    workdir="${PWD:-/app}"
    output_root="${HIGH_RAM_OUTPUT_ROOT:-${workdir}/outputs/rois}"
    aggregated_output_root="${HIGH_RAM_AGGREGATED_OUTPUT_ROOT:-${workdir}/outputs/aggregated_parcellations}"
    parcel_size="${HIGH_RAM_PARCEL_SIZE:-15}"
    aggregate_workers="${HIGH_RAM_AGGREGATE_WORKERS:-1}"
    max_estimated_distance_gb="${HIGH_RAM_MAX_ESTIMATED_DISTANCE_GB:-8}"
    labels_file="${HIGH_RAM_LABELS_FILE:-/app/scripts/parcellation/high_memory_labels.txt}"
    ensure_dir_writable "${output_root}"
    ensure_dir_writable "${aggregated_output_root}"

    if [ -n "${SUB_PARCELS_SEGMENTATION:-}" ]; then
        segmentation="${SUB_PARCELS_SEGMENTATION}"
    elif [ -f "${workdir}/MNI152_T1_1mm_seg.nii.gz" ]; then
        segmentation="${workdir}/MNI152_T1_1mm_seg.nii.gz"
    else
        segmentation="${DEFAULT_SEGMENTATION}"
    fi

    if [ ! -r "${segmentation}" ]; then
        echo "Segmentation file is not readable: ${segmentation}" >&2
        exit 1
    fi

    if [ ! -r "${labels_file}" ]; then
        echo "Labels file is not readable: ${labels_file}" >&2
        exit 1
    fi

    exec python /app/scripts/parcellation/run_high_ram_labels.py \
        --segmentation "${segmentation}" \
        --output-root "${output_root}" \
        --aggregated-output-root "${aggregated_output_root}" \
        --parcel-size "${parcel_size}" \
        --aggregate-workers "${aggregate_workers}" \
        --labels-file "${labels_file}" \
        --max-estimated-distance-gb "${max_estimated_distance_gb}" \
        "$@"
